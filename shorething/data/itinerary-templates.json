{
  "_schema": {
    "_comment": "AUTHORING LAYER — hand-maintained. Each template is one repeating itinerary for a ship: an ordered day-by-day port sequence plus the list of embarkation dates it runs on. A build step (build_sailings.py) expands these into individual dated 'sailings' the app reads, matching the shape a Widgety feed will later provide. To add coverage: add a template here, re-run the build. Port ids MUST exist in ports.json. Use {\"type\":\"sea\"} for sea days (no portId). Day 1 is embarkation day at the departure port; the final day is disembarkation.",
    "template": {
      "id": "stable slug, unique across all templates",
      "line": "line id (matches fleet.json)",
      "ship": "ship id (matches fleet.json, within that line)",
      "name": "display name of the itinerary, e.g. '7-Night Western Caribbean'",
      "nights": "integer — number of nights",
      "days": "ordered array: {day, portId} for a port call, or {day, type:'sea'} for a sea day; day 1 = embarkation",
      "dates": "array of ISO embarkation dates (YYYY-MM-DD) this template runs on",
      "widgetyId": "null for now; maps to Widgety cruise/itinerary reference later"
    }
  },
  "_status": {
    "note": "Princess seed only — illustrative real-shape itineraries to demonstrate the picker end-to-end. Dates are sample 2026 departures. Expand per ship/line as rosters and deployment data are compiled. A ship with NO templates here still appears in the picker; the app routes the user to manual entry for it."
  },
